<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.qk.mapper.ClueMapper">

    <!--id字段与resultMap引用相同-->
    <!--type 最终属性要封装到这个对象中 Clue    -->
    <resultMap id="clueResultMap" type="com.qk.entity.Clue">
        <id property="id" column="id"/>
        <result property="phone" column="phone"/>
        <result property="channel" column="channel"/>
        <result property="activityId" column="activity_id"/>
        <result property="name" column="name"/>
        <result property="gender" column="gender"/>
        <result property="age" column="age"/>
        <result property="wechat" column="wechat"/>
        <result property="qq" column="qq"/>
        <result property="userId" column="user_id"/>
        <result property="status" column="status"/>
        <result property="subject" column="subject"/>
        <result property="level" column="level"/>
        <result property="nextTime" column="next_time"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <!--coLLection标签用于封装对象中的集合类型的属性-->
        <!--ofType标签用户表示我们集合中的单个对象是什么类型-->
        <collection property="trackRecords" ofType="com.qk.entity.ClueTrackRecord">
            <id property="id" column="ct_id"/>
            <result property="clueId" column="ct_clue_id"/>
            <result property="userId" column="ct_user_id"/>
            <result property="subject" column="ct_subject"/>
            <result property="level" column="ct_level"/>
            <result property="record" column="ct_record"/>
            <result property="nextTime" column="ct_next_time"/>
            <result property="type" column="ct_type"/>
            <result property="falseReason" column="ct_false_reason"/>
            <result property="createTime" column="ct_create_time"/>
            <result property="assignName" column="assign_name"/>
        </collection>
    </resultMap>

    <!--resultMap手动封装复杂对象的相应结果-->
    <select id="getClueById" resultMap="clueResultMap">
        select c.id,
               c.phone,
               c.channel,
               c.activity_id,
               c.name,
               c.gender,
               c.age,
               c.wechat,
               c.qq,
               c.user_id,
               c.status,
               c.subject,
               c.level,
               c.next_time,
               c.create_time,
               c.update_time,
               ct.id           as ct_id,
               ct.clue_id      as ct_clue_id,
               ct.user_id      as ct_user_id,
               ct.subject      as ct_subject,
               ct.level        as ct_level,
               ct.record       as ct_record,
               ct.next_time    as ct_next_time,
               ct.type         as ct_type,
               ct.false_reason as ct_false_reason,
               ct.create_time  as ct_create_time,
               u.name          as assign_name
        from clue c
                 left join clue_track_record ct on c.id = ct.clue_id
                 left join user u on ct.user_id = u.id
        where c.id = #{id}
    </select>

    <select id="queryClueList" resultType="com.qk.entity.Clue">
        select c.*, u.name as assignName
        from clue c
        left join user u on c.user_id = u.id
        <where>
            <if test="clueDto.clueId != null">
                c.id=#{clueDto.clueId}
            </if>
            <if test="clueDto.phone != null and clueDto.phone != ''">
                and c.phone=#{clueDto.phone}
            </if>
            <if test="clueDto.status != null">
                and c.status=#{clueDto.status}
            </if>
            <if test="clueDto.channel != null">
                and c.channel=#{clueDto.channel}
            </if>
            <if test="clueDto.assignName != null and clueDto.assignName != ''">
                and u.name=#{clueDto.assignName}
            </if>
        </where>
        order by c.update_time desc
    </select>
    <select id="getClueOverviewData" resultType="com.qk.vo.OverviewVO">
        select count(1)                       as clueTotal,
               count(if(status = 1, 1, null)) as clueWaitAllot,
               count(if(status = 2, 2, null)) as clueWaitFollow,
               count(if(status = 3, 3, null)) as clueFollowing,
               count(if(status = 4, 4, null)) as clueFalse,
               count(if(status = 5, 5, null)) as clueConvertBusiness
        from clue;
    </select>
</mapper>